---
// 鼠标轨迹书法墨痕 canvas（粒子系统版）
// - 头粗尾细：单次笔画起笔大粒子，1.4s 内衰减到细粒子
// - 4 秒后完全消失：每个粒子有 maxLife，到期 splice 删除，画布每帧 clearRect
// - 墨色随主题：读 :root[--ink-color] CSS 变量
---

<canvas class="ink-canvas" data-ink-canvas></canvas>

<style>
  .ink-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }
</style>

<script>
  type Particle = {
    x: number;
    y: number;
    born: number;       // performance.now() at spawn
    life: number;       // ms total
    baseRadius: number; // initial radius
  };

  function initOne(canvas: HTMLCanvasElement) {
    const parent = canvas.parentElement;
    if (!parent) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    let w = 0, h = 0;

    function resize() {
      const rect = parent!.getBoundingClientRect();
      w = rect.width; h = rect.height;
      canvas.width = Math.floor(w * dpr);
      canvas.height = Math.floor(h * dpr);
      canvas.style.width = w + 'px';
      canvas.style.height = h + 'px';
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    resize();
    new ResizeObserver(resize).observe(parent);

    function getInk(): string {
      const v = getComputedStyle(document.documentElement)
        .getPropertyValue('--ink-color')
        .trim();
      return v || '240, 233, 216';
    }

    const particles: Particle[] = [];
    const MAX_PARTICLES = 1200; // 防爆内存

    // 笔触参数
    const STROKE_MAX_SIZE = 5.2;   // 起笔最粒粗
    const STROKE_MIN_SIZE = 0.45;  // 收笔最细
    const TAPER_DURATION = 1.4;    // s，stroke 内多久从粗衰减到细
    const PARTICLE_LIFE_MS = 4000; // 单个粒子寿命：4 秒后彻底消失
    const SPACING = 2.8;           // 粒子间距（沿轨迹插值）

    let last: { x: number; y: number; t: number } | null = null;
    let isInside = false;
    let strokeStart = 0;

    function pointerEvt(e: PointerEvent) {
      const rect = parent!.getBoundingClientRect();
      return { x: e.clientX - rect.left, y: e.clientY - rect.top, t: performance.now() };
    }

    parent.addEventListener('pointerenter', (e) => {
      isInside = true;
      const p = pointerEvt(e);
      last = p;
      strokeStart = p.t;
    });

    parent.addEventListener('pointerleave', () => {
      isInside = false;
      last = null;
    });

    parent.addEventListener('pointermove', (e) => {
      if (!isInside) return;
      const p = pointerEvt(e);
      if (!last) { last = p; strokeStart = p.t; return; }

      const dx = p.x - last.x;
      const dy = p.y - last.y;
      const dist = Math.hypot(dx, dy);
      const steps = Math.max(1, Math.ceil(dist / SPACING));

      for (let i = 1; i <= steps; i++) {
        const tt = i / steps;
        const x = last.x + dx * tt;
        const y = last.y + dy * tt;

        // 笔触粗细：基于 stroke 起始的时间，head 粗 tail 细
        const strokeAge = (last.t + (p.t - last.t) * tt - strokeStart) / 1000;
        const taper = Math.max(0.05, Math.pow(Math.max(0, 1 - strokeAge / TAPER_DURATION), 1.2));
        const radius = STROKE_MIN_SIZE + (STROKE_MAX_SIZE - STROKE_MIN_SIZE) * taper;

        particles.push({
          x, y,
          born: performance.now(),
          life: PARTICLE_LIFE_MS,
          baseRadius: radius,
        });
      }

      // 防爆：只保留最近 MAX_PARTICLES 个
      if (particles.length > MAX_PARTICLES) {
        particles.splice(0, particles.length - MAX_PARTICLES);
      }

      last = p;
    });

    function frame() {
      const now = performance.now();
      ctx!.clearRect(0, 0, w, h);
      const ink = getInk();

      for (let i = particles.length - 1; i >= 0; i--) {
        const pt = particles[i];
        const age = now - pt.born;
        if (age >= pt.life) {
          particles.splice(i, 1);
          continue;
        }
        const lifeT = age / pt.life;
        // ease-out 收缩 + 透明度衰减
        const radius = pt.baseRadius * (1 - Math.pow(lifeT, 1.6) * 0.85);
        const alpha = (1 - lifeT) * 0.72;
        if (radius < 0.15 || alpha < 0.02) continue;
        ctx!.fillStyle = `rgba(${ink}, ${alpha})`;
        ctx!.beginPath();
        ctx!.arc(pt.x, pt.y, radius, 0, Math.PI * 2);
        ctx!.fill();
      }

      requestAnimationFrame(frame);
    }
    frame();
  }

  function init() {
    document.querySelectorAll<HTMLCanvasElement>('canvas[data-ink-canvas]').forEach(initOne);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
