---
// 鼠标轨迹书法墨痕 canvas
// 用法：放在一个 position: relative 的容器内，canvas 会自动撑满父元素
---

<canvas class="ink-canvas" data-ink-canvas></canvas>

<style>
  .ink-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }
</style>

<script>
  type Point = { x: number; y: number; t: number };

  function initOne(canvas: HTMLCanvasElement) {
    const parent = canvas.parentElement;
    if (!parent) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    let w = 0, h = 0;

    function resize() {
      const rect = parent!.getBoundingClientRect();
      w = rect.width; h = rect.height;
      canvas.width = Math.floor(w * dpr);
      canvas.height = Math.floor(h * dpr);
      canvas.style.width = w + 'px';
      canvas.style.height = h + 'px';
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx!.lineCap = 'round';
      ctx!.lineJoin = 'round';
    }
    resize();

    const ro = new ResizeObserver(resize);
    ro.observe(parent);

    let last: Point | null = null;
    let isInside = false;

    function pointerEvt(e: PointerEvent): Point {
      const rect = parent!.getBoundingClientRect();
      return { x: e.clientX - rect.left, y: e.clientY - rect.top, t: performance.now() };
    }

    parent.addEventListener('pointerenter', (e) => {
      isInside = true;
      last = pointerEvt(e);
    });

    parent.addEventListener('pointerleave', () => {
      isInside = false;
      last = null;
    });

    parent.addEventListener('pointermove', (e) => {
      if (!isInside) return;
      const p = pointerEvt(e);
      if (!last) { last = p; return; }

      const dt = Math.max(p.t - last.t, 1);
      const dist = Math.hypot(p.x - last.x, p.y - last.y);
      const speed = dist / dt; // px / ms
      // 慢 → 粗（落笔/顿），快 → 细（带过）
      const width = Math.max(0.4, Math.min(4.5, 4.5 - speed * 1.4));
      // 速度极慢时透明度略高（像饱蘸墨）
      const alpha = Math.max(0.28, Math.min(0.7, 0.7 - speed * 0.18));

      ctx!.strokeStyle = `rgba(240, 233, 216, ${alpha})`;
      ctx!.lineWidth = width;
      ctx!.beginPath();
      ctx!.moveTo(last.x, last.y);
      // 用 quadraticCurveTo 模拟运笔曲线（用中点做控制点）
      const mx = (last.x + p.x) / 2;
      const my = (last.y + p.y) / 2;
      ctx!.quadraticCurveTo(last.x, last.y, mx, my);
      ctx!.lineTo(p.x, p.y);
      ctx!.stroke();

      last = p;
    });

    // 渐隐：每帧把 canvas 整体 alpha 衰减一点
    function fadeLoop() {
      ctx!.save();
      ctx!.globalCompositeOperation = 'destination-out';
      ctx!.fillStyle = 'rgba(0, 0, 0, 0.020)';
      ctx!.fillRect(0, 0, w, h);
      ctx!.restore();
      requestAnimationFrame(fadeLoop);
    }
    fadeLoop();
  }

  function init() {
    document.querySelectorAll<HTMLCanvasElement>('canvas[data-ink-canvas]').forEach(initOne);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
