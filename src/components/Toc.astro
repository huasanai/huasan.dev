---
type Heading = {
  depth: number;
  slug: string;
  text: string;
};

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const items = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 4);

type TocNode = Heading & { children: TocNode[] };

const tree: TocNode[] = [];
const stack: TocNode[] = [];

for (const heading of items) {
  const node = { ...heading, children: [] };

  while (stack.length > 0 && stack[stack.length - 1].depth >= node.depth) {
    stack.pop();
  }

  if (stack.length === 0) {
    tree.push(node);
  } else {
    stack[stack.length - 1].children.push(node);
  }

  stack.push(node);
}
---

{
  tree.length > 0 && (
    <aside class="toc" aria-label="文章目录">
      <div class="toc-inner">
        <nav class="toc-nav">
          <ul class="toc-list">
            {
              tree.map((heading) => (
                <li class:list={['toc-node', `toc-depth-${heading.depth}`, { 'has-children': heading.children.length > 0 }]}>
                  <div class="toc-row">
                    {heading.children.length > 0 ? (
                      <button class="toc-toggle" type="button" aria-expanded="true" aria-label={`折叠 ${heading.text}`} data-toc-toggle>
                        <span aria-hidden="true">›</span>
                      </button>
                    ) : (
                      <span class="toc-toggle-spacer"></span>
                    )}
                    <a href={`#${heading.slug}`} data-toc-link={heading.slug}>
                      {heading.text}
                    </a>
                  </div>
                  {heading.children.length > 0 && (
                    <ul class="toc-children">
                      {heading.children.map((child) => (
                        <li class:list={['toc-node', `toc-depth-${child.depth}`, { 'has-children': child.children.length > 0 }]}>
                          <div class="toc-row">
                            {child.children.length > 0 ? (
                              <button class="toc-toggle" type="button" aria-expanded="true" aria-label={`折叠 ${child.text}`} data-toc-toggle>
                                <span aria-hidden="true">›</span>
                              </button>
                            ) : (
                              <span class="toc-toggle-spacer"></span>
                            )}
                            <a href={`#${child.slug}`} data-toc-link={child.slug}>
                              {child.text}
                            </a>
                          </div>
                          {child.children.length > 0 && (
                            <ul class="toc-children">
                              {child.children.map((grandchild) => (
                                <li class={`toc-node toc-depth-${grandchild.depth}`}>
                                  <div class="toc-row">
                                    <span class="toc-toggle-spacer"></span>
                                    <a href={`#${grandchild.slug}`} data-toc-link={grandchild.slug}>
                                      {grandchild.text}
                                    </a>
                                  </div>
                                </li>
                              ))}
                            </ul>
                          )}
                        </li>
                      ))}
                    </ul>
                  )}
                </li>
              ))
            }
          </ul>
        </nav>
      </div>
    </aside>
  )
}

<script>
  const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]'));
  const headings = tocLinks
    .map((link) => {
      const id = link.dataset.tocLink;
      const target = id ? document.getElementById(id) : null;
      return target ? { id, link, target } : null;
    })
    .filter((item): item is { id: string; link: HTMLAnchorElement; target: HTMLElement } => Boolean(item));

  const setActive = (id: string) => {
    tocLinks.forEach((link) => {
      link.classList.toggle('active', link.dataset.tocLink === id);
    });
  };

  tocLinks.forEach((link) => {
    link.addEventListener('click', (event) => {
      const id = link.dataset.tocLink;
      const target = id ? document.getElementById(id) : null;
      if (!target) return;

      event.preventDefault();
      target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      history.replaceState(null, '', `#${id}`);
      setActive(id);
    });
  });

  document.querySelectorAll<HTMLButtonElement>('[data-toc-toggle]').forEach((button) => {
    button.addEventListener('click', () => {
      const node = button.closest('.toc-node');
      if (!node) return;

      const collapsed = node.classList.toggle('collapsed');
      button.setAttribute('aria-expanded', String(!collapsed));
      button.setAttribute('aria-label', `${collapsed ? '展开' : '折叠'} ${node.querySelector('a')?.textContent?.trim() || ''}`);
    });
  });

  if (headings.length > 0) {
    setActive(headings[0].id);

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

        const first = visible[0]?.target as HTMLElement | undefined;
        if (first?.id) setActive(first.id);
      },
      {
        rootMargin: '-96px 0px -65% 0px',
        threshold: [0, 1],
      }
    );

    headings.forEach(({ target }) => observer.observe(target));
  }
</script>

<style>
  .toc {
    display: none;
  }

  @media (min-width: 1024px) {
    .toc {
      display: block;
      align-self: start;
      min-width: 0;
    }

    .toc-inner {
      position: sticky;
      top: 92px;
      max-height: calc(100vh - 120px);
      overflow: auto;
      padding: 0.25rem 0 0.25rem 1rem;
      border-left: 1px solid var(--post-border-soft);
    }

    .toc ul {
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .toc li {
      margin: 0;
      padding: 0;
    }

    .toc-row {
      display: flex;
      align-items: center;
      gap: 0.1rem;
      min-width: 0;
    }

    .toc-toggle,
    .toc-toggle-spacer {
      flex: 0 0 1rem;
      width: 1rem;
      height: 1.45rem;
    }

    .toc-toggle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      border: 0;
      border-radius: 4px;
      background: transparent;
      color: var(--post-toc-child);
      cursor: pointer;
    }

    .toc-toggle:hover {
      color: var(--post-accent);
      background: var(--post-code-bg);
    }

    .toc-toggle span {
      display: block;
      transform: rotate(90deg);
      transition: transform 0.15s ease;
      font-size: 0.95rem;
      line-height: 1;
    }

    .toc-node.collapsed > .toc-row .toc-toggle span {
      transform: rotate(0deg);
    }

    .toc-node.collapsed > .toc-children {
      display: none;
    }

    .toc a {
      display: block;
      min-width: 0;
      flex: 1 1 auto;
      padding: 0.32rem 0.35rem;
      border-radius: 8px;
      color: var(--post-toc-text);
      font-family: 'JetBrains Mono', 'SF Mono', Menlo, monospace;
      font-size: 0.78rem;
      line-height: 1.35;
      letter-spacing: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .toc a:hover {
      color: var(--post-text);
    }

    .toc a.active {
      color: var(--post-accent);
      background: var(--post-code-bg);
      font-weight: 600;
    }

    .toc-depth-3 > .toc-row {
      padding-left: 0.55rem;
    }

    .toc-depth-4 > .toc-row {
      padding-left: 1.1rem;
    }

    .toc-depth-3 a,
    .toc-depth-4 a {
      color: var(--post-toc-child);
      font-size: 0.75rem;
    }

    .toc-depth-4 a {
      font-size: 0.72rem;
    }

    .toc-depth-3 a.active,
    .toc-depth-4 a.active {
      color: var(--post-accent);
    }
  }
</style>
