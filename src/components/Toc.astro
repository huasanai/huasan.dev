---
type Heading = {
  depth: number;
  slug: string;
  text: string;
};

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const items = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);

const grouped = items.reduce<Array<Heading & { children: Heading[] }>>((acc, heading) => {
  if (heading.depth === 2 || acc.length === 0) {
    acc.push({ ...heading, children: [] });
    return acc;
  }

  acc[acc.length - 1].children.push(heading);
  return acc;
}, []);
---

{
  grouped.length > 0 && (
    <aside class="toc" aria-label="文章目录">
      <div class="toc-inner">
        <nav class="toc-nav">
          <ul>
            {
              grouped.map((heading) => (
                <li>
                  <a href={`#${heading.slug}`} data-toc-link={heading.slug}>
                    {heading.text}
                  </a>
                  {
                    heading.children.length > 0 && (
                      <ul>
                        {
                          heading.children.map((child) => (
                            <li>
                              <a class="toc-child" href={`#${child.slug}`} data-toc-link={child.slug}>
                                {child.text}
                              </a>
                            </li>
                          ))
                        }
                      </ul>
                    )
                  }
                </li>
              ))
            }
          </ul>
        </nav>
      </div>
    </aside>
  )
}

<script>
  const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]'));
  const headings = tocLinks
    .map((link) => {
      const id = link.dataset.tocLink;
      const target = id ? document.getElementById(id) : null;
      return target ? { id, link, target } : null;
    })
    .filter((item): item is { id: string; link: HTMLAnchorElement; target: HTMLElement } => Boolean(item));

  const setActive = (id: string) => {
    tocLinks.forEach((link) => {
      link.classList.toggle('active', link.dataset.tocLink === id);
    });
  };

  tocLinks.forEach((link) => {
    link.addEventListener('click', (event) => {
      const id = link.dataset.tocLink;
      const target = id ? document.getElementById(id) : null;
      if (!target) return;

      event.preventDefault();
      target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      history.replaceState(null, '', `#${id}`);
      setActive(id);
    });
  });

  if (headings.length > 0) {
    setActive(headings[0].id);

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

        const first = visible[0]?.target as HTMLElement | undefined;
        if (first?.id) setActive(first.id);
      },
      {
        rootMargin: '-96px 0px -65% 0px',
        threshold: [0, 1],
      }
    );

    headings.forEach(({ target }) => observer.observe(target));
  }
</script>

<style>
  .toc {
    display: none;
  }

  @media (min-width: 1024px) {
    .toc {
      display: block;
      align-self: start;
      min-width: 0;
    }

    .toc-inner {
      position: sticky;
      top: 92px;
      max-height: calc(100vh - 120px);
      overflow: auto;
      padding: 0.25rem 0 0.25rem 1rem;
      border-left: 1px solid var(--post-border-soft);
    }

    .toc ul {
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .toc li {
      margin: 0;
      padding: 0;
    }

    .toc a {
      display: block;
      padding: 0.32rem 0.35rem;
      border-radius: 8px;
      color: var(--post-toc-text);
      font-family: 'JetBrains Mono', 'SF Mono', Menlo, monospace;
      font-size: 0.78rem;
      line-height: 1.35;
      letter-spacing: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .toc a:hover {
      color: var(--post-text);
    }

    .toc a.active {
      color: var(--post-accent);
      background: var(--post-code-bg);
      font-weight: 600;
    }

    .toc a.toc-child {
      padding-left: 1rem;
      color: var(--post-toc-child);
      font-size: 0.75rem;
    }

    .toc a.toc-child.active {
      color: var(--post-accent);
    }
  }
</style>
