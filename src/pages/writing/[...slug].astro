---
import Layout from '../../layouts/Layout.astro';
import InkCanvas from '../../components/InkCanvas.astro';
import Toc from '../../components/Toc.astro';
import { getCollection, render } from 'astro:content';
import { CURRENT_QUOTE } from '../../lib/quotes';

export async function getStaticPaths() {
  const posts = await getCollection('writing', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const heroQuote = post.data.heroQuote ?? CURRENT_QUOTE.text;
const heroQuoteSrc = post.data.heroQuoteSrc ?? CURRENT_QUOTE.src;

function fmtFull(d: Date) {
  return d.toLocaleString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout title={post.data.title} description={post.data.description}>
  <section class="post-hero" aria-label="文章主题">
    <InkCanvas />
    <div class="post-hero-inner">
      <p class="post-hero-quote">{heroQuote}</p>
      <p class="post-hero-quote-src">— {heroQuoteSrc}</p>
    </div>
  </section>

  <div class="writing-page">
    <div class="writing-shell">
      <article class="post-card post">
        <header class="post-header">
          {post.data.cover && <img class="post-cover" src={post.data.cover} alt="" />}
          <div class="post-meta">
            <span class="mono date">{fmtFull(post.data.pubDate)}</span>
            <span class="mono author">画伞</span>
            {post.data.tags.length > 0 && (
              <span class="post-tags">
                {post.data.tags.map((tag: string) => <span class="tag mono">#{tag}</span>)}
              </span>
            )}
          </div>
          <h1>{post.data.title}</h1>
          {post.data.description && <p class="post-desc">{post.data.description}</p>}
        </header>

        <div class="post-body">
          <Content />
        </div>

        <footer class="post-footer">
          <a href="/writing" class="mono back-link">← back to writing</a>
        </footer>
      </article>

      <Toc headings={headings} />
    </div>
  </div>

  <style>
    :global(main) {
      background: var(--bg);
      padding: 0 0 4rem;
    }

    .post-hero {
      position: relative;
      overflow: hidden;
      background: var(--hero-bg);
      color: var(--hero-text);
      padding: 2rem 0 2.25rem;
    }

    .post-hero-inner {
      max-width: 720px;
      margin: 0 auto;
      padding: 0 1.5rem;
      position: relative;
      z-index: 2;
      pointer-events: none;
    }

    .post-hero-quote {
      font-family: 'TsangerJinKai02', 'STKaiti', 'KaiTi', serif;
      font-size: clamp(1.4rem, 3vw, 2rem);
      font-weight: 400;
      letter-spacing: 0.08em;
      color: var(--hero-text);
      margin: 0;
      line-height: 1.5;
    }

    .post-hero-quote-src {
      font-family: 'TsangerJinKai02', serif;
      font-size: 0.85rem;
      color: var(--hero-text-soft);
      margin: 0.85rem 0 0;
      letter-spacing: 0.05em;
    }

    .writing-page {
      --post-page-bg: #f5f4ed;
      --post-card-bg: #fffdfa;
      --post-text: rgba(36, 41, 47, 0.92);
      --post-text-soft: rgba(36, 41, 47, 0.68);
      --post-text-dim: rgba(36, 41, 47, 0.46);
      --post-border-soft: #e8e0ca;
      --post-shadow: 0 1px 2px rgba(31, 30, 27, 0.04), 0 18px 48px -32px rgba(31, 30, 27, 0.24);
      --post-accent: #c15f3c;
      --post-accent-strong: #a94622;
      --post-code-bg: rgba(224, 123, 61, 0.1);
      --post-code-border: rgba(224, 123, 61, 0.18);
      --post-code-text: #c2410c;
      --post-mermaid-bg: #fbf8f1;
      --post-mermaid-track: #f2e9da;
      --post-mermaid-thumb: rgba(193, 95, 60, 0.34);
      --post-toc-text: rgba(36, 41, 47, 0.62);
      --post-toc-child: rgba(36, 41, 47, 0.48);
      color: var(--post-text);
      padding: 2rem 1rem 0;
    }

    /* 深色模式覆盖：把 light 的 --post-* tokens 全部替换成 dark 版本，
       UI 内部不需要改 var(...) 引用，自动响应主题切换 */
    :global([data-theme='dark']) .writing-page {
      --post-page-bg: #15141A;
      --post-card-bg: #1F1D26;
      --post-text: rgba(240, 233, 216, 0.92);
      --post-text-soft: rgba(240, 233, 216, 0.66);
      --post-text-dim: rgba(240, 233, 216, 0.44);
      --post-border-soft: #2F2D38;
      --post-shadow: 0 1px 2px rgba(0, 0, 0, 0.25), 0 18px 48px -32px rgba(0, 0, 0, 0.6);
      --post-accent: #E07A4F;
      --post-accent-strong: #FF8B5C;
      --post-code-bg: rgba(224, 123, 61, 0.18);
      --post-code-border: rgba(224, 123, 61, 0.34);
      --post-code-text: #FFA877;
      --post-mermaid-bg: #1B1A22;
      --post-mermaid-track: #2A2832;
      --post-mermaid-thumb: rgba(224, 122, 79, 0.42);
      --post-toc-text: rgba(240, 233, 216, 0.6);
      --post-toc-child: rgba(240, 233, 216, 0.42);
    }

    .writing-shell {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 1.5rem;
      max-width: 1140px;
      margin: 0 auto;
    }

    .post-card {
      width: 100%;
      max-width: 860px;
      margin: 0 auto;
      padding: 1rem 1rem 2.5rem;
      background: var(--post-card-bg);
      border: 1px solid var(--post-border-soft);
      border-radius: 8px;
      box-shadow: var(--post-shadow);
    }

    .post-header {
      margin-bottom: 2.5rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid var(--post-border-soft);
    }

    .post-cover {
      display: block;
      width: 100%;
      aspect-ratio: 16 / 9;
      object-fit: cover;
      margin: 0 0 1.7rem;
      border-radius: 6px;
      border: 1px solid var(--post-border-soft);
      background: var(--post-mermaid-bg);
    }

    .post-meta {
      display: flex;
      gap: 1rem;
      color: var(--post-text-dim);
      font-size: 0.78rem;
      margin-bottom: 1rem;
      flex-wrap: wrap;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .post-tags {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }

    .tag {
      color: var(--post-accent-strong);
      text-transform: lowercase;
      letter-spacing: 0;
    }

    .post h1 {
      font-size: clamp(1.75rem, 4vw, 2.45rem);
      margin: 0;
      letter-spacing: 0;
      line-height: 1.25;
      color: var(--post-text);
    }

    .post-desc {
      color: var(--post-text-soft);
      font-size: 1.05rem;
      margin: 1rem 0 0;
    }

    .post-body {
      font-size: 1rem;
      line-height: 1.88;
    }

    .post-body :global(h2),
    .post-body :global(h3) {
      scroll-margin-top: 96px;
    }

    .post-body :global(h2) {
      font-size: 1.4rem;
      margin: 2.6rem 0 1rem;
      padding-top: 1.1rem;
      border-top: 1px solid var(--post-border-soft);
      color: var(--post-text);
    }

    .post-body :global(h3) {
      font-size: 1.15rem;
      margin: 2rem 0 0.75rem;
      color: var(--post-text);
    }

    .post-body :global(p),
    .post-body :global(li) {
      color: var(--post-text);
    }

    .post-body :global(a) {
      color: var(--post-accent-strong);
      border-bottom: 1px dotted rgba(193, 95, 60, 0.42);
    }

    .post-body :global(a:hover) {
      border-bottom-style: solid;
    }

    .post-body :global(img) {
      max-width: 100%;
      height: auto;
      border-radius: 8px;
      margin: 1.5rem 0;
    }

    .post-body :global(ul),
    .post-body :global(ol) {
      padding-left: 1.5rem;
    }

    .post-body :global(li) {
      margin: 0.3em 0;
    }

    .post-body :global(code:not(pre code)) {
      margin: 0 0.08em;
      padding: 0.08em 0.35em;
      border: 1px solid var(--post-code-border);
      border-radius: 3px;
      background: var(--post-code-bg);
      color: var(--post-code-text);
      font-size: 0.9em;
      line-height: inherit;
      white-space: normal;
      overflow-wrap: anywhere;
      word-break: break-word;
      box-decoration-break: clone;
      -webkit-box-decoration-break: clone;
    }

    .post-body :global(.expressive-code) {
      margin: 1.5rem 0;
    }

    .post-body :global(.expressive-code pre) {
      margin: 0;
    }

    .post-body :global(.mermaid-scroll) {
      display: block;
      max-width: 100%;
      margin: 1.5rem auto;
      padding: 1rem;
      overflow-x: auto;             /* wide 图横向滚动，文字保持原大不被压 */
      overflow-y: hidden;
      text-align: center;           /* narrow 图（< 容器宽）自动水平居中 */
      border: 1px solid var(--post-border-soft);
      border-radius: 8px;
      background: var(--post-mermaid-bg);
      -webkit-overflow-scrolling: touch;
    }

    .post-body :global(.mermaid-scroll::-webkit-scrollbar) {
      height: 8px;
    }

    .post-body :global(.mermaid-scroll::-webkit-scrollbar-track) {
      background: var(--post-mermaid-track);
      border-radius: 999px;
    }

    .post-body :global(.mermaid-scroll::-webkit-scrollbar-thumb) {
      background: var(--post-mermaid-thumb);
      border-radius: 999px;
    }

    /* mermaid 客户端渲染前避免 FOUC（raw source 闪一下）*/
    .post-body :global(.mermaid) {
      color: transparent;
      min-height: 60px;
    }
    .post-body :global(.mermaid[data-processed="true"]) {
      color: inherit;
      min-height: 0;
    }

    .post-body :global(.mermaid svg) {
      display: inline-block;
      height: auto;
      margin: 0;
      vertical-align: top;
    }

    /* ---------- 表格 ---------- */
    .post-body :global(table) {
      width: 100%;
      border-collapse: collapse;
      margin: 1.75rem 0;
      font-size: 0.92em;
      background: var(--post-card-bg);
      border: 1px solid var(--post-border-soft);
      border-radius: 6px;
      overflow: hidden;
      line-height: 1.6;
    }

    .post-body :global(thead) {
      background: var(--post-mermaid-bg);
    }

    .post-body :global(th) {
      padding: 0.7rem 0.95rem;
      text-align: left;
      font-weight: 600;
      color: var(--post-text);
      border-bottom: 1.5px solid var(--post-border-soft);
      letter-spacing: 0;
    }

    .post-body :global(td) {
      padding: 0.6rem 0.95rem;
      border-bottom: 1px solid var(--post-border-soft);
      color: var(--post-text);
      vertical-align: top;
    }

    .post-body :global(tbody tr:last-child td) {
      border-bottom: none;
    }

    .post-body :global(tbody tr:hover) {
      background: color-mix(in srgb, var(--post-accent) 5%, transparent);
    }

    /* 表格内行内 code 在表格里再压缩一点 */
    .post-body :global(td code:not(pre code)),
    .post-body :global(th code:not(pre code)) {
      font-size: 0.88em;
    }

    /* 移动端：让表格横向可滚而不撑爆 body */
    @media (max-width: 600px) {
      .post-body :global(table) {
        display: block;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }
    }

    .post-body :global(.mermaid svg foreignObject .nodeLabel),
    .post-body :global(.mermaid svg foreignObject .edgeLabel) {
      line-height: 1.45;
    }

    .post-footer {
      margin-top: 4rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--post-border-soft);
    }

    .back-link {
      color: var(--post-text-dim);
      font-size: 0.85rem;
    }

    .back-link:hover {
      color: var(--post-accent);
    }

    @media (min-width: 768px) {
      :global(main) {
        padding-bottom: 4.5rem;
      }

      .writing-page {
        padding: 3rem 1.5rem 0;
      }

      .post-card {
        padding: 1.25rem 3rem 4rem;
      }
    }

    @media (min-width: 1024px) {
      .writing-shell {
        grid-template-columns: minmax(0, 860px) minmax(180px, 240px);
        align-items: start;
      }

      .post-card {
        margin: 0;
      }
    }

    @media (min-width: 1180px) {
      .post-card {
        padding-left: 4rem;
        padding-right: 4rem;
      }
    }

    @media (max-width: 600px) {
      .post-hero {
        padding: 1.5rem 0 1.75rem;
      }

      .post-hero-quote {
        font-size: 1.2rem;
        letter-spacing: 0.04em;
      }

      .writing-page {
        padding: 1.5rem 0 0;
      }

      .post-card {
        border-left: 0;
        border-right: 0;
        border-radius: 0;
        box-shadow: none;
      }

      .post-meta {
        gap: 0.6rem;
      }
    }
  </style>
</Layout>
