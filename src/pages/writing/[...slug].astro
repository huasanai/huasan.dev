---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('writing', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function fmtFull(d: Date) {
  return d.toLocaleString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout title={post.data.title} description={post.data.description}>
  <article class="container post">
    <header class="post-header">
      <div class="post-meta">
        <span class="mono date">{fmtFull(post.data.pubDate)}</span>
        <span class="mono author">画伞</span>
        {post.data.tags.length > 0 && (
          <span class="post-tags">
            {post.data.tags.map((tag: string) => <span class="tag mono">#{tag}</span>)}
          </span>
        )}
      </div>
      <h1>{post.data.title}</h1>
      {post.data.description && <p class="post-desc">{post.data.description}</p>}
    </header>

    <div class="post-body">
      <Content />
    </div>

    <footer class="post-footer">
      <a href="/writing" class="mono back-link">← back to writing</a>
    </footer>
  </article>

  <style>
    main { padding: 3rem 0 4rem; }
    .post { max-width: 700px; }
    .post-header {
      margin-bottom: 2.5rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid var(--border-soft);
    }
    .post-meta {
      display: flex;
      gap: 1rem;
      color: var(--text-dim);
      font-size: 0.85rem;
      margin-bottom: 1rem;
      flex-wrap: wrap;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .post-tags { display: flex; gap: 0.5rem; }
    .tag { color: var(--accent-soft); text-transform: lowercase; letter-spacing: 0; }
    .post h1 {
      font-size: 2rem;
      margin: 0;
      letter-spacing: 0;
      line-height: 1.3;
    }
    .post-desc {
      color: var(--text-soft);
      font-size: 1.05rem;
      margin: 1rem 0 0;
    }
    .post-body {
      font-size: 1rem;
      line-height: 1.85;
    }
    .post-body :global(h2) {
      font-size: 1.4rem;
      margin: 2.5rem 0 1rem;
      padding-top: 1rem;
      border-top: 1px solid var(--border-soft);
    }
    .post-body :global(h3) {
      font-size: 1.15rem;
      margin: 2rem 0 0.75rem;
    }
    .post-body :global(img) {
      max-width: 100%;
      height: auto;
      border-radius: 10px;
      margin: 1.5rem 0;
    }
    .post-body :global(ul), .post-body :global(ol) {
      padding-left: 1.5rem;
    }
    .post-body :global(li) { margin: 0.3em 0; }

    .post-footer {
      margin-top: 4rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border-soft);
    }
    .back-link {
      color: var(--text-dim);
      font-size: 0.85rem;
    }
    .back-link:hover { color: var(--accent); }
  </style>
</Layout>
