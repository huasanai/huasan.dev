---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<Layout title={project.data.title} description={project.data.tagline}>
  <article class="container post">
    <header class="post-header">
      <div class="post-meta">
        <span class={`status-tag status-${project.data.status}`}>{project.data.status}</span>
        <span class="mono year">{project.data.year}</span>
        {project.data.tags.length > 0 && (
          <span class="post-tags">
            {project.data.tags.map((tag: string) => <span class="tag mono">#{tag}</span>)}
          </span>
        )}
      </div>
      <h1>{project.data.title}</h1>
      <p class="post-desc">{project.data.tagline}</p>
      <div class="post-links">
        {project.data.repo && (
          <a href={project.data.repo} target="_blank" rel="noopener" class="mono">repo ↗</a>
        )}
        {project.data.link && (
          <a href={project.data.link} target="_blank" rel="noopener" class="mono">website ↗</a>
        )}
      </div>
    </header>

    <div class="post-body">
      <Content />
    </div>

    <footer class="post-footer">
      <a href="/projects" class="mono back-link">← back to projects</a>
    </footer>
  </article>

  <style>
    main { padding: 3rem 0 4rem; }
    .post { max-width: 700px; }
    .post-header {
      margin-bottom: 2.5rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid var(--border-soft);
    }
    .post-meta {
      display: flex;
      gap: 0.75rem;
      align-items: center;
      margin-bottom: 1rem;
      flex-wrap: wrap;
    }
    .status-tag {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      padding: 0.15rem 0.55rem;
      border-radius: 999px;
      text-transform: lowercase;
      border: 1px solid transparent;
      letter-spacing: 0;
    }
    .status-active     { background: rgba(193, 95, 60, 0.10); color: var(--accent); border-color: rgba(193, 95, 60, 0.25); }
    .status-experiment { background: rgba(120, 160, 100, 0.10); color: #5C8A4C; border-color: rgba(120, 160, 100, 0.25); }
    .status-paused     { background: rgba(139, 136, 129, 0.10); color: var(--text-soft); border-color: rgba(139, 136, 129, 0.25); }
    .status-archived   { background: rgba(139, 136, 129, 0.08); color: var(--text-dim); border-color: rgba(139, 136, 129, 0.15); }

    .year { color: var(--text-dim); font-size: 0.8rem; }
    .post-tags { display: flex; gap: 0.5rem; }
    .tag { color: var(--accent-soft); letter-spacing: 0; font-size: 0.8rem; }

    .post h1 {
      font-size: 2rem;
      margin: 0;
      letter-spacing: 0;
      line-height: 1.3;
    }
    .post-desc {
      color: var(--text-soft);
      font-size: 1.05rem;
      margin: 1rem 0 0;
    }
    .post-links {
      display: flex;
      gap: 1.25rem;
      margin-top: 1.25rem;
    }
    .post-links a { color: var(--accent); }

    .post-body {
      font-size: 1rem;
      line-height: 1.85;
    }
    .post-body :global(h2) {
      font-size: 1.4rem;
      margin: 2.5rem 0 1rem;
    }
    .post-body :global(img) {
      max-width: 100%;
      height: auto;
      border-radius: 10px;
      margin: 1.5rem 0;
    }

    .post-footer {
      margin-top: 4rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border-soft);
    }
    .back-link { color: var(--text-dim); font-size: 0.85rem; }
    .back-link:hover { color: var(--accent); }
  </style>
</Layout>
